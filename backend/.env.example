DATABASE_URL="postgres://myocatmongo:myocatmongo@localhost:5432/myocatmongo"
PORT=4000
PUBLIC_BASE_URL="http://localhost:4000"
# Base URL used to turn relative /uploads/* paths into absolute URLs in API responses,
# i.e. the address a *browser* can reach. Falls back to PUBLIC_BASE_URL if unset —
# only needs to differ in Docker, where PUBLIC_BASE_URL becomes the internal
# backend:4000 address (for the vision container) while this stays public-facing.
ASSET_PUBLIC_BASE_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:5173"
JWT_SECRET="dev-myocatmongo-secret"
GOOGLE_CLIENT_ID="your-google-web-client-id.apps.googleusercontent.com"
VISION_PROVIDER="mock"
VISION_SERVICE_URL="http://localhost:8001"
VISION_HTTP_FALLBACK_TO_MOCK="true"
# MAIL_PROVIDER=mock logs verification codes to the console instead of sending email.
MAIL_PROVIDER="mock"
MAIL_APP_NAME="묘캣몬고"
MAIL_FROM="묘캣몬고 <no-reply@myocatmongo.local>"
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
