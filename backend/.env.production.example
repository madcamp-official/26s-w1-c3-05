# Copy to .env.production on the kcloud VM and fill in real values.
# DATABASE_URL / VISION_SERVICE_URL / PUBLIC_BASE_URL are overridden by
# docker-compose.yml to use the internal service names (postgres/vision/backend) —
# no need to set them here when running via `docker compose up`.

PORT=4000

# Public URL the frontend/browser hits (kcloud floating IP or domain), used for
# things like CORS and any absolute links returned to clients.
CORS_ORIGIN="https://your-frontend-domain.example"

# The Cloudflare Tunnel (or whatever) public hostname for THIS backend — used to
# turn relative /uploads/* photo paths into absolute URLs the browser can load.
# NOT overridden by docker-compose.yml (unlike PUBLIC_BASE_URL), since this one
# must stay externally resolvable.
ASSET_PUBLIC_BASE_URL="https://api.your-tunnel-domain.example"

# Long random string — do not reuse the dev secret.
JWT_SECRET="generate-a-long-random-value"

GOOGLE_CLIENT_ID="your-google-web-client-id.apps.googleusercontent.com"

VISION_PROVIDER="http"
VISION_HTTP_FALLBACK_TO_MOCK="false"

# From the Cloudflare Zero Trust dashboard (Networks > Tunnels > your tunnel >
# Install connector). Used by the cloudflared service in docker-compose.yml.
TUNNEL_TOKEN=""

MAIL_PROVIDER="smtp"
MAIL_APP_NAME="캣치미"
MAIL_FROM="캣치미 <no-reply@example.com>"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
